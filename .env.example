# ==========================================================
# GOOGLE CLOUD NATURAL LANGUAGE — server-side only
# ==========================================================
# Use ONE of the following. Never expose it in index.html.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}
# GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=BASE64_ENCODED_SERVICE_ACCOUNT_JSON
GOOGLE_NLP_API_VERSION=v2
GOOGLE_NLP_CACHE_TTL_SECONDS=2592000
GOOGLE_NLP_STALE_TTL_SECONDS=7776000
GOOGLE_NLP_MAX_CHARS=90000
GOOGLE_NLP_WARM_LIMIT=3
GOOGLE_NLP_STATUS_TTL_SECONDS=7776000

# ==========================================================
# FINANCIAL EXPRESS CONTENT SOURCES
# ==========================================================
FE_CONTENT_SOURCE_PRIORITY=wordpress,rss,html,static-cache

# WordPress REST API. Tech can replace this URL if FE uses a custom endpoint.
FE_WORDPRESS_ENABLED=true
FE_WORDPRESS_REST_URL=https://www.financialexpress.com/wp-json/wp/v2/posts
FE_WORDPRESS_CACHE_TTL_SECONDS=300
FE_WORDPRESS_STALE_TTL_SECONDS=86400

# RSS: the code first discovers feed URLs from the FE syndication directory.
FE_RSS_ENABLED=true
FE_RSS_DIRECTORY_URL=https://www.financialexpress.com/syndication/
# Optional: comma-separated exact feed URLs supplied by Tech. These override discovery.
# FE_RSS_FEED_URLS=https://example.com/market.xml,https://example.com/economy.xml
FE_RSS_MAX_FEEDS=12
FE_RSS_CACHE_TTL_SECONDS=300
FE_RSS_STALE_TTL_SECONDS=86400

# HTML metadata is the third fallback after WordPress REST and RSS.
FE_HTML_FALLBACK_ENABLED=true
FE_ARTICLE_CACHE_TTL_SECONDS=21600
FE_ARTICLE_STALE_TTL_SECONDS=604800
FE_SOURCE_STATUS_TTL_SECONDS=600
FE_REFRESH_ARTICLE_LIMIT=10

# ==========================================================
# SUPABASE — persistent editorial actions + persistent cache
# ==========================================================
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_ACTIONS_TABLE=fe_editorial_actions
SUPABASE_CACHE_TABLE=fe_semantic_cache

# Local development fallbacks
ALLOW_LOCAL_ACTION_STORAGE=true
ALLOW_LOCAL_CACHE_STORAGE=true

# Protect cache-clear and refresh endpoints.
REFRESH_SECRET=GENERATE_A_LONG_RANDOM_SECRET
# Vercel automatically sends CRON_SECRET as a Bearer token to cron endpoints.
CRON_SECRET=GENERATE_A_DIFFERENT_LONG_RANDOM_SECRET
