FE_LIVE_RECOMMENDATION_CANDIDATES=500
FE_LIVE_RECOMMENDATION_MIN_SUGGESTIONS=2
FE_LIVE_RECOMMENDATION_MAX_SUGGESTIONS=3
FE_LIVE_RECOMMENDATION_MIN_SCORE=50

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=
