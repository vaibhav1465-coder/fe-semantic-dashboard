# FE Semantic Internal Linking - example environment variables
# Keep real credentials only in .env.local or Vercel Environment Variables.
# Never paste a real service-account JSON key into this file.

GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=

