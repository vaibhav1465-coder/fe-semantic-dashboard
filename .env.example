# FE Semantic Internal Linking - example environment variables
# Add real credentials only in .env.local or Vercel Environment Variables.

GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
GOOGLE_NLP_API_VERSION=v2
GOOGLE_NLP_CACHE_TTL_SECONDS=2592000
GOOGLE_NLP_STALE_TTL_SECONDS=7776000
GOOGLE_NLP_MAX_CHARS=90000
GOOGLE_NLP_ENTITY_MAX_CHARS=30000

FE_WORDPRESS_ENABLED=true
FE_WORDPRESS_REST_URL=https://www.financialexpress.com/wp-json/wp/v2/posts
FE_LIVE_RECOMMENDATION_MIN_SCORE=50
FE_LIVE_SOURCE_LIMIT=60
FE_LIVE_CANDIDATE_LIMIT=500
FE_LIVE_RECOMMENDATION_CACHE_TTL_SECONDS=600
FE_LIVE_RECOMMENDATION_STALE_TTL_SECONDS=86400

FE_RSS_ENABLED=true
FE_RSS_DIRECTORY_URL=https://www.financialexpress.com/syndication/

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=
REFRESH_SECRET=
